# LLM Provider (openai or anthropic)
DEFAULT_PROVIDER=openai

# API Keys (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://gateway:gateway@localhost:5432/gateway

# Redis
REDIS_URL=redis://localhost:6379

# Gateway settings
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
LOG_LEVEL=info
DEBUG=false

# Detection settings
DETECTION_THRESHOLD=0.85
DETECTION_SHADOW_MODE=false

# Rate limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# Audit log
AUDIT_LOG_ENABLED=true

# Admin API key (required to use /admin/* endpoints)
ADMIN_API_KEY=change-me-to-a-random-secret

# PQC Proxy master key (32-byte hex, for session encryption at rest)
PQC_PROXY_MASTER_KEY=change-me-to-a-32-byte-hex-secret
